---
import MainLayout from '../../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('life')).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const base = import.meta.env.BASE_URL;
const fmt = (d: Date) => d.toISOString().slice(0, 10);
const coverSrc = (cover?: string) => {
  if (!cover) return '';
  if (cover.startsWith('http://') || cover.startsWith('https://')) return cover;
  const cleanBase = (import.meta.env.BASE_URL || '/').replace(/\/$/, '');
  const cleanCover = cover.startsWith('/') ? cover : `/${cover}`;
  return `${cleanBase}${cleanCover}`;
};
---

<MainLayout title="Life - Minimalist Blog">
  <div class="page-shell">
    <header class="page-head">
      <p class="page-subtitle">After all, tomorrow is another day</p>
    </header>

    <section class="cards-grid" aria-label="Life posts">
      {posts.map((post) => (
        <a class="post-card" href={`${base}life/${post.id}/`}>
          {post.data.cover && (
            <img class="post-cover" src={coverSrc(post.data.cover)} alt={`${post.data.title} cover`} loading="lazy" />
          )}
          <div class="post-body">
            <div class="meta-row">
              <span class="category">Life</span>
            </div>
            <h2 class="post-title">{post.data.title}</h2>
            <p class="post-excerpt">{post.data.excerpt}</p>
            <time class="post-date">{fmt(post.data.date)}</time>
          </div>
        </a>
      ))}
    </section>
  </div>
</MainLayout>

<style>
  .page-shell {
    width: min(1280px, calc(100vw - 64px));
    margin-left: 50%;
    transform: translateX(-50%);
    padding: 8px 0 28px;
  }

  .page-head { margin: 10px 0 24px; }
  .page-title {
    margin: 0;
    font-size: 40px;
    line-height: 1.2;
    letter-spacing: -0.025em;
    font-weight: 400;
  }
  .page-subtitle { margin: 10px 0 0; color: #5d5d5d; font-size: 18px; }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 30px 24px;
    align-items: start;
  }

  .post-card {
    text-decoration: none;
    color: inherit;
    background: #f3f4f4;
    border: 1px solid #ececec;
    display: flex;
    flex-direction: column;
    transition: box-shadow 0.22s ease, transform 0.22s ease, border-color 0.22s ease;
  }
  .post-card:hover {
    border-color: #dcdcc8;
    box-shadow: 0 10px 24px rgba(30, 41, 59, 0.12), 0 2px 8px rgba(30, 41, 59, 0.08);
    transform: translateY(-2px);
  }

  .post-cover {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    display: block;
    background: #e8e8e8;
  }

  .post-body {
    padding: 16px 18px 18px;
    background: #f3f4f4;
  }

  .meta-row {
    display: flex;
    gap: 10px;
    align-items: center;
    color: #696969;
    font-size: 12px;
  }

  .category {
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 400;
  }

  .post-title {
    margin: 10px 0;
    font-size: 25px;
    line-height: 1.16;
    letter-spacing: -0.015em;
    font-weight: 400;
    color: #4b4b4b;
  }

  .post-date {
    display: block;
    margin: 14px 0 10px;
    color: #696969;
    font-size: 12px;
    letter-spacing: 0.02em;
  }

  .post-excerpt {
    margin: 0;
    color: #7a7a7a;
    font-size: 15px;
    line-height: 1.55;
  }

  @media (max-width: 1180px) {
    .page-shell { width: min(1020px, calc(100vw - 36px)); }
    .cards-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }

  :global(html[data-theme='dark']) .page-subtitle,
  :global(html[data-theme='dark']) .meta-row,
  :global(html[data-theme='dark']) .post-date,
  :global(html[data-theme='dark']) .post-excerpt {
    color: var(--text-secondary);
  }

  :global(html[data-theme='dark']) .post-title {
    color: var(--text-heading);
  }

  :global(html[data-theme='dark']) .post-card,
  :global(html[data-theme='dark']) .post-body {
    background: var(--surface-muted);
    border-color: var(--border-subtle);
  }

  @media (max-width: 760px) {
    .page-shell { width: calc(100vw - 24px); }
    .page-title { font-size: 40px; }
    .cards-grid { grid-template-columns: 1fr; gap: 20px; }
    .post-title { font-size: 20px; }
  }
</style>
