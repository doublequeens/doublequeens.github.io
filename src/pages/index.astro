---
import MainLayout from '../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';

const technicalPosts = (await getCollection('technical')).map((post) => ({
  ...post,
  category: 'Technical',
  href: `technical/${post.id}/`,
}));

const lifePosts = (await getCollection('life')).map((post) => ({
  ...post,
  category: 'Life',
  href: `life/${post.id}/`,
}));

const posts = [...technicalPosts, ...lifePosts]
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const latestPost = posts[0];
const remainingPosts = posts.slice(1);

const base = import.meta.env.BASE_URL;
const fmt = (d: Date) => d.toISOString().slice(0, 10);
const coverSrc = (cover?: string) => {
  if (!cover) return '';
  if (cover.startsWith('http://') || cover.startsWith('https://')) return cover;
  const cleanBase = (import.meta.env.BASE_URL || '/').replace(/\/$/, '');
  const cleanCover = cover.startsWith('/') ? cover : `/${cover}`;
  return `${cleanBase}${cleanCover}`;
};
---

<MainLayout title="Blog - Minimalist Blog">
  <div class="page-shell">
    <header class="page-head">
      <h1 class="page-title">Stop overthinking<br />Done is better than perfect</h1>
    </header>

    {latestPost && (
      <section class="featured-wrap" aria-label="Latest post">
        <a class="featured-card" href={`${base}${latestPost.href}`}>
          {latestPost.data.cover && (
            <img
              class="featured-cover"
              src={coverSrc(latestPost.data.cover)}
              alt={`${latestPost.data.title} cover`}
              loading="eager"
            />
          )}
          <div class="featured-body">
            <div class="meta-row">
              <span class="pill">Latest</span>
              <span class="category">{latestPost.category}</span>
            </div>
            <h2 class="featured-title">{latestPost.data.title}</h2>
            <p class="featured-excerpt">{latestPost.data.excerpt}</p>
            <time class="featured-date">{fmt(latestPost.data.date)}</time>
          </div>
        </a>
      </section>
    )}

    <section class="stories-wrap" aria-label="More posts">
      <h2 class="section-title">More stories</h2>
      <div class="cards-grid">
        {remainingPosts.map((post) => (
          <a class="post-card" href={`${base}${post.href}`}>
            {post.data.cover && (
              <img class="post-cover" src={coverSrc(post.data.cover)} alt={`${post.data.title} cover`} loading="lazy" />
            )}
            <div class="post-body">
              <div class="meta-row">
                <span class="category">{post.category}</span>
              </div>
              <h3 class="post-title">{post.data.title}</h3>
              <p class="post-excerpt">{post.data.excerpt}</p>
              <time class="post-date">{fmt(post.data.date)}</time>
            </div>
          </a>
        ))}
      </div>
    </section>
  </div>
</MainLayout>

<style>
  .page-shell {
    width: min(1280px, calc(100vw - 64px));
    margin-left: 50%;
    transform: translateX(-50%);
    padding: 8px 0 28px;
  }

  .page-head { margin: 10px 0 50px; }
  .page-title {
    margin: 0;
    font-size: 25px;
    line-height: 1.2;
    letter-spacing: -0.025em;
    font-weight: 600;
    color: #4b4b4b;
  }
  .page-subtitle { margin: 12px 0 0; font-size: 19px; color: #5b5b5b; }

  .featured-wrap { margin-bottom: 34px; }
  .featured-card {
    display: grid;
    grid-template-columns: minmax(0, 1.55fr) minmax(360px, 1fr);
    text-decoration: none;
    color: inherit;
    background: #f3f4f4;
    border: 1px solid #ececec;
    overflow: hidden;
    transition: box-shadow 0.22s ease, transform 0.22s ease, border-color 0.22s ease;
  }
  .featured-card:hover {
    border-color: #dcdcc8;
    box-shadow: 0 12px 30px rgba(30, 41, 59, 0.14), 0 3px 10px rgba(30, 41, 59, 0.08);
    transform: translateY(-2px);
  }
  .featured-cover {
    width: 100%;
    height: 100%;
    min-height: 410px;
    object-fit: cover;
    display: block;
    background: #e8e8e8;
  }
  .featured-body {
    padding: 30px 30px 32px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    background: #f3f4f4;
  }
  .featured-title {
    margin: 14px 0 14px;
    font-size: 25px;
    line-height: 1.08;
    letter-spacing: -0.02em;
    font-weight: 400;
    color: #4b4b4b;
  }
  .featured-date {
    display: block;
    margin: 14px 0 12px;
    color: #696969;
    font-size: 12px;
    letter-spacing: 0.02em;
  }

  .featured-excerpt {
    margin: 0;
    color: #7a7a7a;
    font-size: 17px;
    line-height: 1.6;
  }

  .section-title {
    margin: 0 0 18px;
    font-size: 32px;
    line-height: 1.2;
    letter-spacing: -0.01em;
    color: #4b4b4b;
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 30px 24px;
    align-items: start;
  }

  .post-card {
    text-decoration: none;
    color: inherit;
    background: #f3f4f4;
    border: 1px solid #ececec;
    display: flex;
    flex-direction: column;
    transition: box-shadow 0.22s ease, transform 0.22s ease, border-color 0.22s ease;
  }
  .post-card:hover {
    border-color: #dcdcc8;
    box-shadow: 0 10px 24px rgba(30, 41, 59, 0.12), 0 2px 8px rgba(30, 41, 59, 0.08);
    transform: translateY(-2px);
  }

  .post-cover {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    display: block;
    background: #e8e8e8;
  }

  .post-body {
    padding: 16px 18px 18px;
    background: #f3f4f4;
  }

  .meta-row {
    display: flex;
    align-items: center;
    gap: 10px;
    color: #696969;
    font-size: 12px;
    margin: 0;
  }

  .pill {
    display: inline-flex;
    align-items: center;
    height: 22px;
    border-radius: 999px;
    padding: 0 10px;
    background: #111;
    color: #fff;
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.02em;
  }

  .category {
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 400;
  }

  .post-title {
    margin: 10px 0 10px;
    font-size: 25px;
    line-height: 1.17;
    letter-spacing: -0.015em;
    font-weight: 400;
    color: #4b4b4b;
  }

  .post-date {
    display: block;
    margin: 14px 0 10px;
    color: #696969;
    font-size: 12px;
    letter-spacing: 0.02em;
  }

  .post-excerpt {
    margin: 0;
    color: #7a7a7a;
    font-size: 15px;
    line-height: 1.55;
  }

  @media (max-width: 1180px) {
    .page-shell { width: min(1020px, calc(100vw - 36px)); }
    .featured-card { grid-template-columns: 1fr; }
    .featured-cover { min-height: 340px; }
    .featured-title { font-size: 25px; }
    .cards-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }

  :global(html[data-theme='dark']) .page-title,
  :global(html[data-theme='dark']) .featured-title,
  :global(html[data-theme='dark']) .section-title,
  :global(html[data-theme='dark']) .post-title {
    color: var(--text-heading);
  }

  :global(html[data-theme='dark']) .featured-excerpt,
  :global(html[data-theme='dark']) .post-excerpt,
  :global(html[data-theme='dark']) .meta-row,
  :global(html[data-theme='dark']) .featured-date,
  :global(html[data-theme='dark']) .post-date {
    color: var(--text-secondary);
  }

  :global(html[data-theme='dark']) .featured-card,
  :global(html[data-theme='dark']) .post-card,
  :global(html[data-theme='dark']) .featured-body,
  :global(html[data-theme='dark']) .post-body {
    background: var(--surface-muted);
    border-color: var(--border-subtle);
  }

  :global(html[data-theme='dark']) .pill {
    background: #2d3325;
    color: #e5e7eb;
  }

  @media (max-width: 760px) {
    .page-shell { width: calc(100vw - 24px); }
    .page-title { font-size: 27px; }
    .page-subtitle { font-size: 16px; }
    .featured-body { padding: 20px 18px 22px; }
    .featured-title { font-size: 20px; }
    .section-title { font-size: 26px; }
    .cards-grid { grid-template-columns: 1fr; gap: 20px; }
    .post-title { font-size: 20px; }
  }
</style>
