---
import Logo from './Logo.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;
const navItems = [
  { name: 'Home', href: `${base}` },
  { name: 'Technical', href: `${base}technical/` },
  { name: 'Life', href: `${base}life/` },
  { name: 'About', href: `${base}about/` }
];

const technicalPosts = await getCollection('technical');
const lifePosts = await getCollection('life');

const searchItems = [
  ...technicalPosts.map((post) => ({
    title: post.data.title,
    href: `${base}technical/${post.id}/`,
    date: post.data.date?.toISOString?.().slice(0, 10) || '',
    category: 'Technical',
    searchText: `${post.data.title} ${post.data.excerpt || ''} ${post.body || ''}`.toLowerCase()
  })),
  ...lifePosts.map((post) => ({
    title: post.data.title,
    href: `${base}life/${post.id}/`,
    date: post.data.date?.toISOString?.().slice(0, 10) || '',
    category: 'Life',
    searchText: `${post.data.title} ${post.data.excerpt || ''} ${post.body || ''}`.toLowerCase()
  }))
].sort((a, b) => (a.date < b.date ? 1 : -1));
---

<header class="header">
  <div class="bar">
    <a href={base} class="brand" aria-label="John Q home">
      <Logo class="brand-logo" />
    </a>

    <nav class="nav" aria-label="Main navigation">
      {navItems.map((item) => (
        <a href={item.href} class="nav-link">{item.name}</a>
      ))}
    </nav>

    <div class="right-actions">
      <button class="search-open-btn" type="button" data-open-search aria-label="Open search" title="Search">
        <svg class="search-open-icon" viewBox="0 0 24 24" aria-hidden="true" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2" />
          <path d="M20 20L16.65 16.65" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
        </svg>
      </button>
    </div>
  </div>
</header>

<div class="search-modal" data-search-modal hidden>
  <div class="search-backdrop" data-close-search></div>
  <div class="search-dialog" role="dialog" aria-modal="true" aria-label="Site search">
    <div class="search-dialog-head">
      <input
        class="search-dialog-input"
        type="search"
        placeholder="Enter keyword..."
        aria-label="Search posts"
        data-search-input
      />
      <button class="search-dialog-close" type="button" data-close-search aria-label="Close search">
        <svg class="search-dialog-icon" viewBox="0 0 24 24" aria-hidden="true" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2" />
          <path d="M20 20L16.65 16.65" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
        </svg>
      </button>
    </div>
    <div class="search-results" data-search-results></div>
  </div>
</div>

<script type="application/json" id="site-search-data" set:html={JSON.stringify(searchItems)}></script>

<style>
  .header {
    padding: 18px 0 14px;
    border-bottom: none;
  }

  .bar {
    width: min(1280px, calc(100vw - 64px));
    margin-left: 50%;
    transform: translateX(-50%);
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 18px;
  }

  .brand,
  .right-actions {
    display: inline-flex;
    align-items: center;
    white-space: nowrap;
  }

  .brand {
    text-decoration: none;
    color: #6b8e23;
  }

  :global(.brand-logo) {
    width: 220px;
    height: auto;
    display: block;
  }

  .right-actions {
    justify-self: end;
  }

  .search-open-btn {
    border: 1px solid #d9ddc7;
    background: #f8f9f2;
    color: #4b4b4b;
    border-radius: 999px;
    width: 38px;
    height: 38px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    cursor: pointer;
  }

  .search-open-icon {
    width: 18px;
    height: 18px;
    display: block;
  }

  .search-open-btn:hover {
    border-color: #b8bf90;
    color: #787838;
  }

  .nav {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 30px;
  }

  .nav-link {
    font-size: 20px;
    color: #4b4b4b;
    text-decoration: none;
    font-weight: 400;
    letter-spacing: -0.01em;
    line-height: 1;
  }

  .nav-link:hover { color: #111; }

  .search-modal[hidden] { display: none; }

  .search-modal {
    position: fixed;
    inset: 0;
    z-index: 1000;
  }

  .search-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(15, 23, 42, 0.58);
    backdrop-filter: blur(8px);
  }

  .search-dialog {
    position: relative;
    margin: 12vh auto 0;
    width: min(780px, calc(100vw - 24px));
    background: transparent;
    border: 0;
    box-shadow: none;
    overflow: visible;
  }

  .search-dialog-head {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 10px;
    width: min(484px, calc(100% - 24px));
    margin: 0 auto;
    padding: 10px;
    border: 1px solid #d7dcc3;
    border-radius: 14px;
    background: #f5f7ef;
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.12);
  }

  .search-dialog-input {
    flex: 1;
    max-width: none;
    border: 0;
    background: transparent;
    border-radius: 10px;
    padding: 10px 12px;
    outline: none;
    font-size: 16px;
    color: #2b2f1f;
  }

  .search-dialog-input:focus {
    box-shadow: none;
  }

  .search-dialog-input::-webkit-search-cancel-button {
    -webkit-appearance: none;
    appearance: none;
    display: none;
  }

  .search-dialog-input::-ms-clear,
  .search-dialog-input::-ms-reveal {
    display: none;
    width: 0;
    height: 0;
  }

  .search-dialog-close {
    border: 0;
    width: 34px;
    height: 34px;
    border-radius: 999px;
    background: #787838;
    color: #ffffff;
    cursor: pointer;
    font-size: 16px;
    line-height: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .search-dialog-close:hover {
    background: #8f9756;
  }

  .search-dialog-icon {
    width: 16px;
    height: 16px;
    display: block;
  }

  .search-results {
    width: min(484px, calc(100% - 24px));
    margin: 10px auto 0;
    max-height: min(58vh, 460px);
    overflow: auto;
    padding: 6px;
    background: #f5f7ef;
    border: 1px solid #d7dcc3;
    border-radius: 14px;
    box-shadow: 0 8px 18px rgba(0, 0, 0, 0.1);
  }

  .search-results:empty {
    display: none;
  }

  :global(.search-item) {
    display: block;
    text-decoration: none;
    color: #2b2f1f;
    border-radius: 0;
    padding: 12px 12px;
    transition: background-color 0.15s ease;
  }

  :global(.search-item + .search-item) {
    border-top: 1px solid #aeb58f;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.35);
  }

  :global(.search-item:visited) {
    color: #2b2f1f;
  }

  :global(.search-item:hover) {
    background: #ecefdf;
  }

  :global(.search-item-title) {
    margin: 0;
    color: #2b2f1f;
    font-size: 16px;
    line-height: 1.35;
  }


  :global(.search-empty) {
    margin: 8px;
    padding: 12px;
    color: #6b7280;
    font-size: 14px;
  }

  @media (max-width: 1180px) {
    .bar {
      width: min(1020px, calc(100vw - 36px));
    }

    :global(.brand-logo) {
      width: 200px;
    }

    .nav-link {
      font-size: 20px;
    }
  }

  :global(html[data-theme='dark']) :global(.brand-logo) {
    filter: drop-shadow(0 0 2px rgba(183, 193, 139, 0.05));
  }

  :global(html[data-theme='dark']) .nav-link {
    color: var(--text-heading);
  }

  :global(html[data-theme='dark']) .nav-link:hover {
    color: var(--text-heading);
    opacity: 0.9;
  }

  :global(html[data-theme='dark']) .search-open-btn {
    background: #1b2018;
    border-color: #3a4332;
    color: var(--text-secondary);
  }

  :global(html[data-theme='dark']) .search-dialog-head,
  :global(html[data-theme='dark']) .search-results {
    background: #1a1f18;
    border-color: #3a4332;
  }

  :global(html[data-theme='dark']) .search-dialog-input,
  :global(html[data-theme='dark']) :global(.search-item),
  :global(html[data-theme='dark']) :global(.search-item-title) {
    color: var(--text-primary);
  }

  :global(html[data-theme='dark']) :global(.search-item:hover) {
    background: #262d23;
  }

  @media (max-width: 760px) {
    .bar {
      width: calc(100vw - 24px);
      grid-template-columns: 1fr;
      gap: 12px;
    }

    :global(.brand-logo) {
      width: 150px;
    }

    .nav {
      justify-content: flex-start;
      flex-wrap: wrap;
      gap: 14px;
    }

    .nav-link {
      font-size: 24px;
    }

    .right-actions { display: none; }

    .search-dialog {
      margin-top: 5vh;
      width: calc(100vw - 16px);
    }
  }
</style>

<script>
  const openBtn = document.querySelector('[data-open-search]');
  const modal = document.querySelector('[data-search-modal]');
  const input = document.querySelector('[data-search-input]');
  const resultsBox = document.querySelector('[data-search-results]');
  const closeTargets = document.querySelectorAll('[data-close-search]');
  const raw = document.getElementById('site-search-data')?.textContent || '[]';
  const searchData = JSON.parse(raw);

  const renderResults = (items, keyword = '') => {
    if (!resultsBox) return;

    if (!keyword.trim()) {
      resultsBox.innerHTML = '';
      return;
    }

    if (!items.length) {
      resultsBox.innerHTML = '<p class="search-empty">No matching posts found.</p>';
      return;
    }

    resultsBox.innerHTML = items
      .map(
        (item) => `
          <a class="search-item" href="${item.href}">
            <p class="search-item-title">${item.title}</p>
          </a>
        `
      )
      .join('');
  };

  const doSearch = () => {
    if (!input) return;
    const keyword = input.value.trim().toLowerCase();
    const matched = searchData
      .filter((item) => (item.searchText || '').includes(keyword))
      .slice(0, 12);
    renderResults(matched, keyword);
  };

  const openModal = () => {
    if (!modal) return;
    modal.hidden = false;
    document.body.style.overflow = 'hidden';
    setTimeout(() => input?.focus(), 0);
  };

  const closeModal = () => {
    if (!modal) return;
    modal.hidden = true;
    document.body.style.overflow = '';
    if (input) input.value = '';
    renderResults([], '');
  };

  openBtn?.addEventListener('click', openModal);
  closeTargets.forEach((el) => el.addEventListener('click', closeModal));
  input?.addEventListener('input', doSearch);
  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape' && modal && !modal.hidden) closeModal();
  });
</script>
