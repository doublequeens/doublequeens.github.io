---
// src/components/ArticleCard.astro

interface Props {
  title: string;
  excerpt: string;
  date: Date;
  category: string;
  readTime?: string;
}

const { title, excerpt, date, category, readTime } = Astro.props;

const formatDate = (date: Date) => {
  return date.toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric'
  });
};
---

<article class="card">
  <h2 class="card-title">{title}</h2>
  <div class="card-meta">
    <time class="card-date">{formatDate(date)}</time>
    <span class="card-category">{category}</span>
    {readTime && <span class="card-read-time">{readTime}</span>}
  </div>
  <p class="card-excerpt">{excerpt}</p>
</article>

<style>
  .card {
    background: #ffffff;
    border: 1px solid #e5e5e5;
    border-radius: 8px;
    padding: 24px;
    margin-bottom: 24px;
    transition: all 0.3s ease;
  }

  .card:hover {
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    border-color: #d1d1d1;
    transform: translateY(-2px);
  }

  .card-title {
    font-size: 22px;
    font-weight: 400;
    color: #000000;
    margin-bottom: 12px;
    line-height: 1.3;
  }

  .card-meta {
    display: flex;
    gap: 8px;
    align-items: center;
    margin-bottom: 24px;
  }

  .card-date {
    font-size: 13px;
    color: #666666;
  }

  .card-category {
    display: inline-block;
    padding: 4px 12px;
    background: #f5f5f5;
    border-radius: 12px;
    font-size: 12px;
    font-weight: 500;
    color: #666666;
  }

  .card-read-time {
    font-size: 13px;
    color: #999999;
  }

  .card-excerpt {
    font-size: 15px;
    color: #333333;
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
