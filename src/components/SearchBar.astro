---
// src/components/SearchBar.astro

const handleSearch = (event: Event) => {
  event.preventDefault();
  const query = (event.target as HTMLFormElement).querySelector('input').value;
  if (query) {
    // 使用 GitHub 搜索
    window.open(`https://github.com/yourusername/minimal-blog/search?q=${encodeURIComponent(query)}`);
  }
};
---

<div class="search-container">
  <form class="search-form" @submit={handleSearch}>
    <input
      type="search"
      placeholder="Search articles..."
      class="search-input"
    />
    <button type="submit" class="search-button">🔍</button>
  </form>
</div>

<style>
  .search-container {
    padding: 32px 0;
    border-top: 1px solid #e5e5e5;
    margin-top: 48px;
  }

  .search-form {
    display: flex;
    gap: 8px;
    max-width: 680px;
    margin: 0 auto;
  }

  .search-input {
    flex: 1;
    padding: 12px 16px;
    border: 1px solid #e5e5e5;
    border-radius: 8px;
    font-size: 14px;
    font-family: inherit;
    box-sizing: border-box;
  }

  .search-input:focus {
    outline: none;
    border-color: rgba(0, 0, 128, 1);
    box-shadow: 0 0 0 3px rgba(0, 0, 128, 0.3);
  }

  .search-button {
    padding: 12px 16px;
    background: #ffffff;
    border: 1px solid #e5e5e5;
    border-radius: 8px;
    cursor: pointer;
    font-size: 16px;
    transition: all 0.2s ease;
  }

  .search-button:hover {
    background: #fafafa;
    border-color: #d1d1d1;
  }
</style>
