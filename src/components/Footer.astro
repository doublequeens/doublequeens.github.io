---
const xUrl = 'https://x.com/JohnQ_201';
const githubUrl = 'https://github.com/doublequeens';
---

<footer class="footer">
  <div class="footer-inner">
    <nav class="footer-links" aria-label="Footer links">
      <a href={xUrl} target="_blank" rel="noopener noreferrer" aria-label="X">
        <svg viewBox="0 0 24 24" aria-hidden="true" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M4 4L20 20" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          <path d="M20 4L4 20" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </a>
      <a href={githubUrl} target="_blank" rel="noopener noreferrer" aria-label="GitHub">
        <svg viewBox="0 0 24 24" aria-hidden="true" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M9 19c-4.3 1.4-4.3-2.5-6-3m12 6v-3.5c0-1 .1-1.4-.5-2 2.8-.3 5.5-1.4 5.5-6a4.6 4.6 0 0 0-1.3-3.2 4.3 4.3 0 0 0-.1-3.2s-1-.3-3.3 1.3a11.5 11.5 0 0 0-6 0C7 3.8 6 4.1 6 4.1a4.3 4.3 0 0 0-.1 3.2A4.6 4.6 0 0 0 4.6 10.5c0 4.6 2.7 5.7 5.5 6-.6.6-.6 1.2-.6 2V22" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </nav>

    <button class="theme-line" type="button" data-theme-cycle aria-label="Toggle theme mode">
      <span class="theme-icon" data-theme-icon>☀</span>
      <span data-theme-label>Light theme</span>
    </button>
  </div>
</footer>

<style>
  .footer {
    padding: 36px 0 30px;
  }

  .footer-inner {
    width: min(1280px, calc(100vw - 64px));
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 23px;
  }

  .footer-links {
    display: inline-flex;
    gap: 14px;
  }

  .footer-links a {
    width: 20px;
    height: 20px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #ffffff;
    text-decoration: none;
    background: #111111;
    border-radius: 4px;
  }

  .footer-links a svg {
    width: 10px;
    height: 10px;
  }

  .theme-line {
    border: 0;
    background: transparent;
    color: #adadad;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 13px;
    line-height: 1;
    cursor: pointer;
    padding: 0;
  }

  .theme-line span[data-theme-label] {
    font-size: 13px;
    font-weight: 300;
  }

  .theme-icon {
    font-size: 11px;
  }

  :global(html[data-theme='dark']) .footer {
    border-top-color: #2f3727;
  }

  :global(html[data-theme='dark']) .footer-links a {
    background: #ffffff;
    color: #111111;
  }

  :global(html[data-theme='dark']) .theme-line {
    color: #cfd4c2;
  }

  @media (prefers-color-scheme: dark) {
    :global(html:not([data-theme='light']):not([data-theme='dark'])) .footer-links a {
      background: #ffffff;
      color: #111111;
    }
  }

  @media (max-width: 760px) {
    .footer-inner {
      width: calc(100vw - 24px);
    }

    .theme-line {
      font-size: 16px;
    }

    .theme-line span[data-theme-label] {
      font-size: 16px;
    }

    .theme-icon {
      font-size: 14px;
    }
  }
</style>

<script>
  const THEME_KEY = 'johnq-theme';
  const themeBtn = document.querySelector('[data-theme-cycle]');
  const themeLabel = document.querySelector('[data-theme-label]');
  const themeIcon = document.querySelector('[data-theme-icon]');
  const order = ['light', 'dark', 'system'];

  const applyTheme = (mode) => {
    const root = document.documentElement;

    if (mode === 'system') {
      root.removeAttribute('data-theme');
      localStorage.setItem(THEME_KEY, 'system');
      if (themeLabel) themeLabel.textContent = 'System theme';
      if (themeIcon) themeIcon.textContent = '◐';
    } else if (mode === 'dark') {
      root.setAttribute('data-theme', 'dark');
      localStorage.setItem(THEME_KEY, 'dark');
      if (themeLabel) themeLabel.textContent = 'Dark theme';
      if (themeIcon) themeIcon.textContent = '☾';
    } else {
      root.setAttribute('data-theme', 'light');
      localStorage.setItem(THEME_KEY, 'light');
      if (themeLabel) themeLabel.textContent = 'Light theme';
      if (themeIcon) themeIcon.textContent = '☀';
    }

    themeBtn?.setAttribute('title', `Click to switch theme (${mode})`);
  };

  const current = localStorage.getItem(THEME_KEY) || 'system';
  applyTheme(current);

  const switchThemeWithEffect = (nextMode, event) => {
    const supportsTransition = typeof document !== 'undefined' && 'startViewTransition' in document;

    if (supportsTransition && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      const x = event?.clientX ?? window.innerWidth / 2;
      const y = event?.clientY ?? window.innerHeight / 2;
      document.documentElement.style.setProperty('--theme-x', `${x}px`);
      document.documentElement.style.setProperty('--theme-y', `${y}px`);

      document.startViewTransition(() => {
        applyTheme(nextMode);
      });
      return;
    }

    applyTheme(nextMode);
  };

  themeBtn?.addEventListener('click', (event) => {
    const mode = localStorage.getItem(THEME_KEY) || 'system';
    const next = order[(order.indexOf(mode) + 1) % order.length];
    switchThemeWithEffect(next, event);
  });
</script>
